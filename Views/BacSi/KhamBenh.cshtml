@model dynamic
@{
    ViewData["Title"] = "Thông tin bệnh nhân";
    var maPhong = ViewBag.MaPhongKham?.ToString() ?? "";
    bool isMainRoom = maPhong == "PK01" || maPhong == "PK02" || maPhong == "PK03";
}

<div class="container mt-4">
    <div class="card shadow-sm border-0">
        <div class="card-header bg-light py-3">
            <h4 class="mb-0"><strong>Thông tin bệnh nhân</strong></h4>
        </div>

        <div class="card-body">
            <!-- Thông tin cơ bản -->
            <div class="row g-3 mb-4">
                <div class="col-md-3">
                    <label class="form-label fw-bold">Mã BN</label>
                    <input type="text" class="form-control bg-light" value="@Model.maBenhNhan" readonly />
                </div>
                <div class="col-md-3">
                    <label class="form-label fw-bold">Mã khám</label>
                    <input type="text" class="form-control bg-light" value="@Model.maKhamBenh" readonly />
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-bold">Họ tên</label>
                    <input type="text" class="form-control bg-light" value="@Model.hoTen" readonly />
                </div>

                <div class="col-md-3">
                    <label class="form-label fw-bold">Giới tính</label>
                    <input type="text" class="form-control bg-light" value="@Model.gioiTinh" readonly />
                </div>
                <div class="col-md-3">
                    <label class="form-label fw-bold">Năm sinh</label>
                    <input type="text" class="form-control bg-light" value="@Model.namSinh" readonly />
                </div>
                <div class="col-md-3">
                    <label class="form-label fw-bold">Chiều cao (m)</label>
                    <input type="text" class="form-control bg-light" value="@Model.chieuCao" readonly />
                </div>
                <div class="col-md-3">
                    <label class="form-label fw-bold">Cân nặng (kg)</label>
                    <input type="text" class="form-control bg-light" value="@Model.canNang" readonly />
                </div>
            </div>

            @if (isMainRoom)
            {
                <!-- Phòng chính: Triệu chứng + Chẩn đoán -->
                <form asp-action="CapNhatChanDoan" method="post">

                    <input type="hidden" name="maKhamBenh" value="@Model.maKhamBenh" />
                    <input type="hidden" name="maPhongKham" value="@ViewBag.MaPhongKham" />

                    <div class="mb-4">
                        <label class="form-label fw-bold">Triệu chứng</label>
                        <textarea name="trieuChung"
                                  class="form-control"
                                  rows="5">@Model.trieuChung</textarea>
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-bold">Chẩn đoán cuối cùng</label>
                        <textarea name="chanDoanCuoiCung"
                                  class="form-control"
                                  rows="5">@Model.chanDoanCuoiCung</textarea>
                    </div>

                    <div class="d-flex flex-wrap gap-2 mt-4">

                        <a asp-action="ChonXetNghiem"
                           asp-route-maKhamBenh="@Model.maKhamBenh"
                           asp-route-maBenhNhan="@Model.maBenhNhan"
                           asp-route-maPhongKham="@ViewBag.MaPhongKham"
                           class="btn btn-warning px-4">
                            Cho đi xét nghiệm
                        </a>

                        <button type="submit" class="btn btn-primary px-4">
                            Lưu chẩn đoán
                        </button>

                        <a asp-action="KeToaThuoc"
                           asp-route-maKhamBenh="@Model.maKhamBenh"
                           class="btn btn-success px-4">
                            Kê toa thuốc
                        </a>

                    </div>

                </form>
            }
            else
            {
                <form asp-action="CapNhatGhiChu" method="post" class="mb-4">
                    <input type="hidden" name="id" value="@ViewBag.ID" />
                    <input type="hidden" name="maPhongKham" value="@ViewBag.MaPhongKham" />

                    <div class="mb-3">
                        <label class="form-label fw-bold">Ghi chú khám</label>
                        <textarea name="ghiChu" class="form-control" rows="6" 
                                  placeholder="Nhập ghi chú khám..." required></textarea>
                    </div>

                    <button type="submit" class="btn btn-primary px-4">
                        <i class="bi bi-save"></i> Lưu ghi chú khám
                    </button>
                </form>
            }
        </div>
    </div>
</div>