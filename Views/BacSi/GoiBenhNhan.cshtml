@model IEnumerable<dynamic>
@{
    ViewData["Title"] = "Gọi bệnh nhân - Phòng " + ViewBag.MaPhongKham;
}

<h3 class="mb-4">Bệnh nhân đang chờ khám - Phòng @ViewBag.MaPhongKham</h3>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}

@if (!Model.Any())
{
    <div class="alert alert-info">Hiện tại không có bệnh nhân nào đang chờ.</div>
}
else
{
    <table class="table table-hover align-middle">
        <thead class="table-light">
            <tr>
                <th>Mã BN</th>
                <th>Họ tên</th>
                <th>Giới tính</th>
                <th>Năm sinh</th>
                <th>Số điện thoại</th>
                <th>Thời gian</th>
                <th class="text-center">Thao tác</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var bn in Model)
            {
                <tr>
                    <td><strong>@bn.maBenhNhan</strong></td>
                    <td>@bn.hoTen</td>
                    <td>@bn.gioiTinh</td>
                    <td>@bn.namSinh</td>
                    <td>@bn.soDienThoai</td>
                    <td>@bn.ngayKham.ToString("HH:mm dd/MM/yyyy")</td>
                    <td class="text-center">
                        <!-- Đã đổi thành link chuyển sang trang KhamBenh -->
                        <a asp-action="KhamBenh" 
                           asp-route-maBenhNhan="@bn.maBenhNhan"
                           asp-route-maKhamBenh="@bn.maKhamBenh"
                           asp-route-maPhongKham="@ViewBag.MaPhongKham"
                           class="btn btn-primary btn-sm">
                            Gọi khám
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

<a asp-action="Index" class="btn btn-secondary mt-3">← Quay lại lịch làm việc</a>