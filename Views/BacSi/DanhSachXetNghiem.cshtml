@model IEnumerable<dynamic>
@{
    ViewData["Title"] = "Danh sách bệnh nhân đã xét nghiệm";
}

<h3 class="mb-4 text-primary">
    <i class="bi bi-clipboard-data me-2"></i> Danh sách bệnh nhân đã xét nghiệm (Trạng thái 2)
</h3>

@if (!Model.Any())
{
    <div class="alert alert-info">Hiện tại chưa có bệnh nhân nào hoàn thành xét nghiệm.</div>
}
else
{
    <table class="table table-hover align-middle shadow-sm">
        <thead class="table-light">
            <tr>
                <th>Mã BN</th>
                <th>Họ tên</th>
                <th>Giới tính</th>
                <th>Năm sinh</th>
                <th>Thời gian</th>
                <th class="text-center">Số xét nghiệm</th>
                <th>Phòng</th>
                <th class="text-center">Thao tác</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var bn in Model)
            {
                <tr>
                    <td><strong>@bn.maBenhNhan</strong></td>
                    <td>@bn.hoTen</td>
                    <td>@bn.gioiTinh</td>
                    <td>@bn.namSinh</td>
                    <td>@bn.ngayKham.ToString("dd/MM/yyyy HH:mm")</td>
                    
                    <!-- Cột mới -->
                    <td class="text-center">
                        <span class="badge bg-info fs-6">@bn.SoLuongXetNghiem</span>
                    </td>

                    <td>@bn.tenPhongKham</td>
                    
                    <td class="text-center">
                        <a asp-action="ChiTietXetNghiem" 
                           asp-route-maKhamBenh="@bn.maKhamBenh"
                           class="btn btn-outline-primary btn-sm">
                            <i class="bi bi-eye"></i> Xem chi tiết
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}