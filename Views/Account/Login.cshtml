@model QLBenhVien.Models.LoginViewModel
@{
    ViewData["Title"] = "Đăng nhập - Bệnh viện";
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <title>Đăng nhập Hệ thống Bệnh viện</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />

    <style>
        body {
            min-height: 100vh;
            background: linear-gradient(135deg, #0d6efd, #20c997);
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: "Segoe UI", sans-serif;
        }

        .login-card {
            width: 100%;
            max-width: 420px;
            border: none;
            border-radius: 20px;
            overflow: hidden;
            box-shadow: 0 20px 45px rgba(0, 0, 0, 0.2);
        }

        .login-header {
            background: #ffffff;
            text-align: center;
            padding: 30px 25px 15px;
        }

        .login-icon {
            width: 70px;
            height: 70px;
            background: #0d6efd;
            color: white;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 15px;
            font-size: 32px;
            font-weight: bold;
        }

        .login-title {
            font-weight: 700;
            color: #0d6efd;
            margin-bottom: 5px;
        }

        .login-subtitle {
            color: #6c757d;
            font-size: 14px;
        }

        .card-body {
            padding: 30px;
            background: white;
        }

        .form-control {
            border-radius: 12px;
            padding: 12px 14px;
        }

        .form-control:focus {
            box-shadow: 0 0 0 0.2rem rgba(13, 110, 253, .15);
        }

        .btn-login {
            border-radius: 12px;
            padding: 12px;
            font-weight: 600;
            background: linear-gradient(135deg, #0d6efd, #0dcaf0);
            border: none;
        }

        .btn-login:hover {
            opacity: 0.95;
        }

        .footer-text {
            text-align: center;
            font-size: 13px;
            color: #6c757d;
            margin-top: 20px;
        }
    </style>
</head>

<body>
    <div class="card login-card">
        <div class="login-header">
            <div class="login-icon">+</div>
            <h4 class="login-title">QL Bệnh Viện</h4>
            <p class="login-subtitle">Đăng nhập để tiếp tục sử dụng hệ thống</p>
        </div>

        <div class="card-body">
            <form asp-action="Login" method="post">
                <div class="mb-3">
                    <label class="form-label fw-semibold">Tài khoản</label>
                    <input asp-for="Username" class="form-control" placeholder="Nhập tài khoản" required />
                </div>

                <div class="mb-3">
                    <label class="form-label fw-semibold">Mật khẩu</label>
                    <input asp-for="Password" type="password" class="form-control" placeholder="Nhập mật khẩu" required />
                </div>

                <button type="submit" class="btn btn-primary btn-login w-100 mt-2">
                    Đăng nhập
                </button>
            </form>

            @if (!string.IsNullOrEmpty(ViewBag.Error))
            {
                <div class="alert alert-danger mt-3 mb-0">
                    @ViewBag.Error
                </div>
            }

            @if (!ViewData.ModelState.IsValid)
            {
                <div class="alert alert-danger mt-3 mb-0">
                    @Html.ValidationSummary(true, "", new { @class = "text-danger mb-0" })
                </div>
            }

            <div class="footer-text">
                Hệ thống quản lý bệnh viện
            </div>
        </div>
    </div>
</body>
</html>