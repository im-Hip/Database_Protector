<div class="d-flex flex-column flex-shrink-0 p-3 bg-light" style="width: 250px; min-height: 100vh;">
    <div class="mb-3">
        <span class="fs-5 fw-semibold text-primary">Bác sĩ</span>
    </div>

    <ul class="nav nav-pills flex-column mb-auto">
        
        <!-- Khám bệnh -->
        <li class="nav-item">
            <a class="nav-link @(ViewContext.RouteData.Values["Action"]?.ToString() == "Index" ? "active" : "")" 
               asp-controller="BacSi" asp-action="Index">
                <i class="bi bi-heart-pulse me-2"></i> Khám bệnh
            </a>
        </li>

        <!-- Danh sách bệnh nhân xét nghiệm -->
        @await Component.InvokeAsync("DoctorSidebarMenu")

    </ul>
</div>