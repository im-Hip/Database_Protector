<!-- Sidebar cho Tiếp tân - Điều phối -->
<div class="d-flex flex-column flex-shrink-0 p-3 bg-light" style="width: 250px; min-height: 100vh;">
    <div class="mb-3">
        <span class="fs-5 fw-semibold text-primary">Tiếp tân - Điều phối</span>
    </div>

    <ul class="nav nav-pills flex-column mb-auto">
        
        <!-- Danh sách bệnh nhân -->
        <li class="nav-item">
            <a class="nav-link @(ViewContext.RouteData.Values["Action"]?.ToString() == "DanhSachBenhNhan" ? "active" : "")" 
               asp-controller="DieuPhoi" asp-action="DanhSachBenhNhan">
                <i class="bi bi-people me-2"></i> Danh sách bệnh nhân
            </a>
        </li>

        <!-- Thêm bệnh nhân mới -->
        <li class="nav-item">
            <a class="nav-link @(ViewContext.RouteData.Values["Action"]?.ToString() == "ThemBenhNhan" ? "active" : "")" 
               asp-controller="DieuPhoi" asp-action="ThemBenhNhan">
                <i class="bi bi-person-plus me-2"></i> Thêm bệnh nhân mới
            </a>
        </li>

        <!-- Điều phối bệnh nhân (sắp làm) -->
        <li class="nav-item">
            <a class="nav-link @(ViewContext.RouteData.Values["Action"]?.ToString() == "DieuPhoi" ? "active" : "")" 
               asp-controller="DieuPhoi" asp-action="DieuPhoi">
                <i class="bi bi-calendar-check me-2"></i> Điều phối bệnh nhân
            </a>
        </li>
    </ul>
</div>