@model QLBenhVien.Models.BenhNhan

@{
    ViewData["Title"] = "Thêm bệnh nhân - Tiếp tân";
    Layout = "_Layout";
}

<h2>Thêm bệnh nhân mới</h2>

<form asp-action="ThemBenhNhan" method="post">
    <div class="row">
        <div class="col-md-6">
            <label>Họ tên</label>
            <input asp-for="hoTen" class="form-control" required />
        </div>
        <div class="col-md-3">
            <label>Giới tính</label>
            <select asp-for="gioiTinh" class="form-select">
                <option value="Nam">Nam</option>
                <option value="Nữ">Nữ</option>
            </select>
        </div>
        <div class="col-md-3">
            <label>Năm sinh</label>
            <input asp-for="namSinh" type="number" class="form-control" />
        </div>
    </div>

    <div class="row mt-3">
        <div class="col-md-3">
            <label>Chiều cao (cm)</label>
            <input asp-for="chieuCao" type="number" step="0.1" class="form-control" />
        </div>
        <div class="col-md-3">
            <label>Cân nặng (kg)</label>
            <input asp-for="canNang" type="number" step="0.1" class="form-control" />
        </div>
        <div class="col-md-6">
            <label>Số điện thoại</label>
            <input asp-for="soDienThoai" class="form-control" />
        </div>
    </div>

    <div class="mt-3">
        <label>Địa chỉ</label>
        <input asp-for="diaChi" class="form-control" />
    </div>

    <button type="submit" class="btn btn-success mt-4">Lưu bệnh nhân</button>
    <a asp-action="DanhSachBenhNhan" class="btn btn-secondary mt-4">Quay lại</a>
</form>